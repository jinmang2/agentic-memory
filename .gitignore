# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets / local env (never commit API keys)
.env
.env.local
.env.*.local

# local/session state
.omc/
*.log
nohup.out
.pytest_cache/

# Reproduction run logs are a durable, git-tracked record (docs/14): un-ignore
# them despite the global *.log above so nothing from a run is volatile.
!results/repro/logs/
!results/repro/logs/*.log
